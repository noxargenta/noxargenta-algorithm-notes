@echo off
:: 设定编码，防止中文显示乱码
chcp 65001 >nul

echo =======================================
echo 开始自动同步算法代码到 GitHub...
echo =======================================

:: 1. 抓取所有有改动或新增的代码文件
git add .

:: 2. 给这次打包写个备注（自动用当前时间作为备注）
git commit -m "Auto Sync: %date% %time%"

:: 3. 推送到 GitHub (origin 表示云端，main 表示主分支)
git push origin main

echo.
echo =======================================
echo 同步完成啦！可以关闭窗口了。
echo =======================================
pause